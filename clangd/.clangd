CompileFlags:
  Add:
    - -Wall
    - -Wextra
    - -Wpedantic
  Compiler: clang

---
If:
  PathMatch: .*\.c$
CompileFlags:
  Add:
    - -xc
    - -std=c11
    - -D_GNU_SOURCE
  Remove:
    - -std=c++*

---
If:
  PathMatch: .*\.cpp$|.*\.cc$|.*\.cxx$
CompileFlags:
  Add:
    - -xc++
    - -std=c++20
  Remove:
    - -std=c*
    - -xc
