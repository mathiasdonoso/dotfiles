general {
	output_format = i3bar
	colors = true
	interval = 5
}

order += "volume /"
order += "memory /"
order += "battery all"
order += "cpu_temperature 0"
order += "load"
order += "tztime local"

battery all {
	format = "%status %percentage %remaining"
}

tztime local {
	format = "%Y-%m-%d %H:%M:%S"
}

load {
	format = "%5min"
}

memory {
	memory_used_method = classical
	format="Memory: %used/%total"
}

volume master {
	format = "♪: %volume"
	format_muted = "♪: muted (%volume)"
	device = "default"
}

cpu_temperature 0 {
	format = "T: %degrees °C"
	path = "/sys/devices/platform/coretemp.0/hwmon/hwmon*/temp1_input"
}
